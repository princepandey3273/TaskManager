<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | TaskManager</title>
    <!-- Google Fonts for Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Link the compiled Tailwind output file -->
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 antialiased m-0 p-0 flex flex-col min-h-screen" style="font-family: 'Inter', sans-serif;">
    
    <!-- Render Reusable Navbar -->
    <%- include('navbar') %>

    <!-- Main Content Wrapper (Supports up to 7xl for wider layouts) -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 py-12 flex flex-col items-center">
