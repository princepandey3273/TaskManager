<!-- Global Toast Notification Container -->
<div id="toast-container" class="fixed bottom-4 right-4 z-[100] flex flex-col gap-3 pointer-events-none"></div>

<script>
/**
 * Global Toast Notification System
 * Easily callable from anywhere in the frontend code.
 * 
 * @param {string} type - 'success', 'error', 'info', or 'warning'
 * @param {string} message - The message to display
 */
function showToast(type, message) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    
    // Base styles
    toast.className = 'pointer-events-auto w-80 max-w-full rounded-2xl p-4 shadow-2xl transform transition-all duration-300 translate-y-10 opacity-0 flex items-start gap-3 border backdrop-blur-md';
    
    // Type-specific styles
    let icon = '';
    if (type === 'success') {
        toast.classList.add('bg-emerald-50/90', 'border-emerald-200', 'text-emerald-800');
        icon = '<svg class="w-6 h-6 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
    } else if (type === 'error') {
        toast.classList.add('bg-rose-50/90', 'border-rose-200', 'text-rose-800');
        icon = '<svg class="w-6 h-6 shrink-0 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
    }

    toast.innerHTML = `
        ${icon}
        <div class="flex-grow">
            <p class="text-sm font-bold">${type === 'success' ? 'Success' : 'Error'}</p>
            <p class="text-sm font-medium opacity-90 mt-0.5">${message}</p>
        </div>
        <button class="toast-close-btn shrink-0 text-current opacity-50 hover:opacity-100 transition-opacity">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    `;

    container.appendChild(toast);

    // Animate in
    requestAnimationFrame(() => {
        toast.classList.remove('translate-y-10', 'opacity-0');
    });

    // Auto remove after 4 seconds
    setTimeout(() => {
        toast.classList.add('translate-y-10', 'opacity-0');
        setTimeout(() => {
            if (container.contains(toast)) toast.remove();
        }, 300);
    }, 4000);
}

// Delegate toast close events globally
document.addEventListener('click', (e) => {
    const closeBtn = e.target.closest('.toast-close-btn');
    if (closeBtn) {
        const toast = closeBtn.closest('.pointer-events-auto');
        if (toast) toast.remove();
    }
});

// Automatically show SSR errors if they exist (passed from backend)
<% if (locals.error) { %>
    document.addEventListener('DOMContentLoaded', () => {
        showToast('error', `<%= locals.error %>`);
    });
<% } %>

// Automatically show SSR successes if they exist (passed from backend)
<% if (locals.success) { %>
    document.addEventListener('DOMContentLoaded', () => {
        showToast('success', `<%= locals.success %>`);
    });
<% } %>
</script>
