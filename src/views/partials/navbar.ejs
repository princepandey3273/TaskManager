<!-- Glassmorphism Navbar Component -->
<header class="sticky top-0 z-50 bg-white/70 backdrop-blur-md border-b border-slate-200 py-4 px-4 md:px-8 flex flex-col md:flex-row justify-between items-center shadow-sm gap-4 w-full">
    <div class="flex items-center space-x-3 group cursor-pointer">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-600 to-purple-600 flex items-center justify-center text-white shadow-lg transform group-hover:rotate-12 transition-transform duration-300 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-800">Task<span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">Manager</span></h2>
    </div>
    
    <nav class="flex flex-wrap justify-center gap-3 md:gap-6 items-center">
        <a href="/" class="text-slate-600 hover:text-indigo-600 transition-colors duration-200 font-semibold text-sm">Overview</a>
        <a href="/api-docs" class="text-slate-600 hover:text-indigo-600 transition-colors duration-200 font-semibold text-sm">API Docs</a>
        
        <div class="h-5 w-px bg-slate-300 mx-2 hidden sm:block"></div>
        
        <% if (locals.user) { %>
            <a href="/dashboard" class="text-slate-600 hover:text-indigo-600 transition-colors duration-200 font-semibold text-sm">Dashboard</a>
            <a href="/logout" class="px-5 py-2.5 rounded-full bg-rose-50 text-rose-600 text-sm font-semibold hover:bg-rose-100 transition-all duration-300 shadow-sm hover:shadow transform hover:-translate-y-0.5">Log Out</a>
        <% } else { %>
            <a href="/login" class="text-slate-600 hover:text-indigo-600 transition-colors duration-200 font-semibold text-sm">Sign In</a>
            <a href="/register" class="px-5 py-2.5 rounded-full bg-slate-900 text-white text-sm font-semibold hover:bg-slate-800 transition-all duration-300 shadow-md hover:shadow-xl transform hover:-translate-y-0.5">Get Started</a>
        <% } %>
    </nav>
</header>
