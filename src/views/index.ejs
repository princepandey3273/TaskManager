<%- include('partials/header') %>

<!-- Hero Section -->
<div class="text-center max-w-4xl mx-auto mt-8 mb-20">
    <div class="inline-block mb-6 px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-100">
        <span class="text-xs font-bold text-indigo-600 uppercase tracking-wider">v1.0 is Live</span>
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-8 leading-[1.1]">
        Next-Generation <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500">Task Management API</span>
    </h1>
    <p class="text-lg md:text-xl text-slate-500 leading-relaxed mb-10 max-w-2xl mx-auto font-medium px-4">
        A production-ready, highly secure REST API engineered with Express.js and MongoDB. Built for extreme scalability, secured by JWT, and fully documented.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 px-6">
        <a href="/api-docs" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold text-lg shadow-lg hover:shadow-indigo-500/30 transition-all duration-300 transform hover:-translate-y-1">View Documentation</a>
        <a href="https://github.com/prince3273" target="_blank" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-white border border-slate-200 text-slate-700 font-bold text-lg shadow-sm hover:bg-slate-50 hover:border-slate-300 transition-all duration-300">View Source</a>
    </div>
</div>

<!-- Feature Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full max-w-6xl mx-auto">
    <!-- Card 1 -->
    <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 transform hover:-translate-y-2 overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 mb-3">Enterprise Security</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
            Protected by advanced JWT authentication, strict Joi request validation, Helmet HTTP headers, and robust NoSQL injection prevention.
        </p>
    </div>

    <!-- Card 2 -->
    <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500 transform hover:-translate-y-2 overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-400 to-pink-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 mb-3">Interactive Docs</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
            Stop guessing endpoints. Test the entire API directly from your browser using the built-in, interactive Swagger UI portal.
        </p>
    </div>

    <!-- Card 3 -->
    <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-pink-500/10 transition-all duration-500 transform hover:-translate-y-2 overflow-hidden md:col-span-2 lg:col-span-1">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pink-400 to-rose-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 bg-pink-50 text-pink-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 mb-3">High Performance</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
            Architected specifically for speed. Clean abstractions, lightweight middlewares, and zero-overhead JSON serialization.
        </p>
    </div>
</div>

<%- include('partials/footer') %>
