<%- include('partials/header') %>

<div class="w-full max-w-7xl mx-auto my-6 sm:my-12 px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 sm:mb-10 text-center md:text-left gap-6">
        <div>
            <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight mb-2">Welcome, <%= user.name %>!</h1>
            <p class="text-slate-500 font-medium text-base sm:text-lg">Here's an overview of your account and tasks.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-end w-full md:w-auto">
            <a href="/api-docs" class="w-full sm:w-auto justify-center px-6 py-3 rounded-xl bg-white border border-slate-200 text-slate-700 font-bold shadow-sm hover:bg-slate-50 hover:border-slate-300 transition-all duration-200 flex items-center">
                Test API
            </a>
            <a href="/tasks" class="w-full sm:w-auto justify-center px-6 py-3 rounded-xl bg-indigo-600 text-white font-bold shadow-md hover:bg-indigo-700 hover:shadow-lg transition-all duration-200 flex items-center group">
                <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                Manage Tasks
            </a>
        </div>
    </div>

    <!-- User Profile Card -->
    <div class="bg-white rounded-3xl p-6 sm:p-8 border border-slate-100 shadow-xl shadow-slate-200/50 mb-10 flex flex-col sm:flex-row items-center gap-6 sm:gap-8 text-center sm:text-left">
        <div class="w-20 h-20 sm:w-24 sm:h-24 shrink-0 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center text-white text-3xl sm:text-4xl font-bold shadow-inner">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div class="flex-grow text-center md:text-left">
            <h2 class="text-2xl font-bold text-slate-800"><%= user.name %></h2>
            <p class="text-slate-500 font-medium mb-4"><%= user.email %></p>
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-bold text-slate-600 uppercase tracking-wider">
                Role: <%= user.role %>
            </div>
        </div>
    </div>

    <!-- Tasks Interaction Section -->
    <div class="bg-slate-900 rounded-3xl p-8 shadow-2xl relative overflow-hidden mb-12">
        <!-- Background Decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 blur-3xl rounded-full transform translate-x-1/2 -translate-y-1/2"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
            <div>
                <h3 class="text-2xl font-bold text-white mb-2">Native UI is Ready!</h3>
                <p class="text-slate-400 font-medium max-w-md">We've built a full-stack, server-rendered task management UI. You no longer need to rely on API fetches to interact with your data.</p>
            </div>
            
            <a href="/tasks" class="px-8 py-4 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold transition-all duration-300 shadow-lg backdrop-blur-sm flex items-center justify-center shrink-0 w-full md:w-auto">
                Go to Task Manager
                <svg class="w-5 h-5 ml-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
