<%- include('../partials/header') %>

<div class="w-full max-w-7xl mx-auto my-6 sm:my-12 px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row justify-between items-center mb-8 text-center sm:text-left gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Task Management</h1>
            <p class="text-slate-500 font-medium">Create, view, and manage your tasks.</p>
        </div>
    </div>

    <!-- Error Message -->
    <% if (locals.error) { %>
        <div class="mb-8 p-4 rounded-xl text-sm font-semibold transition-all duration-300 bg-rose-50 text-rose-700 border border-rose-200 animate-shake">
            <%= locals.error %>
        </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column: Create Task Form -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-200/50 sticky top-24">
                <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Task
                </h2>
                
                <form id="createTaskForm" class="space-y-5">
                    <div>
                        <label for="title" class="block text-sm font-semibold text-slate-700 mb-2">Title</label>
                        <input type="text" id="title" name="title" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 text-slate-800"
                            placeholder="What needs to be done?">
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">Description</label>
                        <textarea id="description" name="description" rows="4" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 text-slate-800 resize-none"
                            placeholder="Add some details..."></textarea>
                    </div>

                    <div>
                        <label for="status" class="block text-sm font-semibold text-slate-700 mb-2">Status</label>
                        <select id="status" name="status"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 text-slate-800 font-medium cursor-pointer appearance-none">
                            <option value="pending" selected>Pending</option>
                            <option value="in-progress">In Progress</option>
                            <option value="completed">Completed</option>
                        </select>
                    </div>

                    <button type="submit"
                        class="w-full py-3.5 mt-2 rounded-xl bg-indigo-600 text-white font-bold shadow-md hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/30 transition-all duration-200 flex justify-center items-center transform hover:-translate-y-0.5">
                        Create Task
                    </button>
                </form>
            </div>
        </div>

        <!-- Right Column: Task List -->
        <div id="tasksList" class="lg:col-span-2 space-y-4">
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(task => { %>
                    <div id="task-<%= task._id %>" class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all duration-200 group flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                        <div class="flex-grow">
                            <div class="flex items-center space-x-3 mb-2">
                                <h3 class="text-lg font-bold text-slate-800"><%= task.title %></h3>
                                <% if (task.status === 'completed') { %>
                                    <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-emerald-100 text-emerald-700 uppercase tracking-wider">Completed</span>
                                <% } else if (task.status === 'in-progress') { %>
                                    <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-blue-100 text-blue-700 uppercase tracking-wider">In Progress</span>
                                <% } else { %>
                                    <span class="px-2.5 py-1 rounded-md text-xs font-bold bg-amber-100 text-amber-700 uppercase tracking-wider">Pending</span>
                                <% } %>
                            </div>
                            <p class="text-slate-600 text-sm whitespace-pre-wrap"><%= task.description %></p>
                            <div class="mt-4 text-xs font-medium text-slate-400 task-date">
                                Created: <%= new Date(task.createdAt).toLocaleDateString() %>
                            </div>
                        </div>

                        <div class="flex flex-row sm:flex-col gap-2 shrink-0 w-full sm:w-auto mt-4 sm:mt-0">
                            <!-- Edit Button -->
                            <a href="/tasks/<%= task._id %>/edit" 
                               class="flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-bold rounded-lg transition-colors">
                                Edit
                            </a>
                            
                            <!-- Delete Button -->
                            <button data-task-id="<%= task._id %>" 
                                class="delete-task-btn w-full sm:w-auto flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2.5 bg-rose-50 hover:bg-rose-100 text-rose-600 text-sm font-bold rounded-lg transition-colors">
                                Delete
                            </button>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white rounded-3xl p-12 border border-slate-100 shadow-sm text-center flex flex-col items-center justify-center h-full min-h-[400px]">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-6">
                        <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">No tasks found</h3>
                    <p class="text-slate-500 font-medium max-w-sm mx-auto">You don't have any tasks yet. Create your first task using the form to get started!</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- AJAX Script -->
<script>
    // Create Task via AJAX
    document.getElementById('createTaskForm').addEventListener('submit', async (e) => {
        e.preventDefault(); // Prevent standard POST
        
        const btn = e.target.querySelector('button[type="submit"]');
        
        // Safely cache original text using dataset to prevent double-overwrites
        if (!btn.dataset.originalText) {
            btn.dataset.originalText = btn.innerHTML;
        }
        
        btn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 inline" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
        btn.disabled = true;

        const payload = {
            title: document.getElementById('title').value,
            description: document.getElementById('description').value,
            status: document.getElementById('status').value
        };

        try {
            const response = await fetch('/api/v1/tasks', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (!response.ok) {
                throw new Error(result.message || 'Failed to create task');
            }

            // Success! Reload page to show new task (or we could dynamically inject HTML)
            // Since EJS rendering logic is complex for badges, reloading is a clean UX 
            // if we want to ensure everything is perfect. But the user asked to "update UI dynamically"
            
            // Let's dynamically inject the HTML
            const task = result.data.task;
            const tasksContainer = document.getElementById('tasksList');
            
            // Remove the "No tasks found" message if it exists
            const noTasks = tasksContainer.querySelector('.text-center.h-full');
            if (noTasks) noTasks.remove();

            const statusBadge = task.status === 'completed' 
                ? '<span class="px-2.5 py-1 rounded-md text-xs font-bold bg-emerald-100 text-emerald-700 uppercase tracking-wider">Completed</span>'
                : task.status === 'in-progress'
                ? '<span class="px-2.5 py-1 rounded-md text-xs font-bold bg-blue-100 text-blue-700 uppercase tracking-wider">In Progress</span>'
                : '<span class="px-2.5 py-1 rounded-md text-xs font-bold bg-amber-100 text-amber-700 uppercase tracking-wider">Pending</span>';

            const newCard = document.createElement('div');
            newCard.id = `task-${task._id}`;
            newCard.className = "bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all duration-200 group flex flex-col sm:flex-row sm:items-start justify-between gap-4 animate-fade-in";
            
            newCard.innerHTML = `
                <div class="flex-grow">
                    <div class="flex items-center space-x-3 mb-2">
                        <h3 class="text-lg font-bold text-slate-800">${task.title}</h3>
                        ${statusBadge}
                    </div>
                    <p class="text-slate-600 text-sm whitespace-pre-wrap">${task.description}</p>
                    <div class="mt-4 text-xs font-medium text-slate-400">
                        Created: ${new Date(task.createdAt).toLocaleDateString()}
                    </div>
                </div>
                <div class="flex flex-row sm:flex-col gap-2 shrink-0 w-full sm:w-auto mt-4 sm:mt-0">
                    <a href="/tasks/${task._id}/edit" class="flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-bold rounded-lg transition-colors">Edit</a>
                    <button data-task-id="${task._id}" class="delete-task-btn w-full sm:w-auto flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2.5 bg-rose-50 hover:bg-rose-100 text-rose-600 text-sm font-bold rounded-lg transition-colors">Delete</button>
                </div>
            `;

            // Prepend new card
            tasksContainer.prepend(newCard);

            // Clear form
            e.target.reset();

            // Show global success toast
            showToast('success', 'Task created successfully!');

        } catch (error) {
            showToast('error', error.message);
        } finally {
            btn.innerHTML = btn.dataset.originalText;
            btn.disabled = false;
        }
    });

    // Event delegation for Delete buttons
    document.getElementById('tasksList').addEventListener('click', async (e) => {
        const deleteBtn = e.target.closest('.delete-task-btn');
        if (!deleteBtn) return;
        
        const taskId = deleteBtn.dataset.taskId;
        if (!confirm('Are you sure you want to delete this task?')) return;

        // Set button state
        const originalText = deleteBtn.innerHTML;
        deleteBtn.innerHTML = '...';
        deleteBtn.disabled = true;

        try {
            const response = await fetch(`/api/v1/tasks/${taskId}`, {
                method: 'DELETE'
            });

            if (!response.ok) {
                const result = await response.json();
                throw new Error(result.message || 'Failed to delete task');
            }

            // Remove card from UI dynamically
            const card = document.getElementById(`task-${taskId}`);
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'scale(0.95)';
                setTimeout(() => card.remove(), 200);
            }
            
            showToast('success', 'Task deleted successfully!');

        } catch (error) {
            showToast('error', error.message);
            deleteBtn.innerHTML = originalText;
            deleteBtn.disabled = false;
        }
    });
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.3s ease-out forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<%- include('../partials/footer') %>
